# Server Configuration
PORT=5001

# Database - Use MongoDB Atlas connection string for production
# Example: mongodb+srv://username:password@cluster.mongodb.net/sicbo?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/sicbo

# JWT Secret - Generate a secure random string for production
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_in_production

# JWT Refresh Secret - Generate a different secure random string for production
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production

# Client URL - Set to your frontend URL in production
CLIENT_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
